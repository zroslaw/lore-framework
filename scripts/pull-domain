#!/usr/bin/env bash
# pull-domain — pull all git repos in the domain directory in parallel

set -uo pipefail

DOMAIN_DIR="${1:-.}"

C_NAME='\033[0;34m'
C_OK='\033[0;32m'
C_FAIL='\033[0;31m'
BOLD='\033[1m'
RESET='\033[0m'

repos=()
for dir in "$DOMAIN_DIR"/*/; do
  [[ -d "$dir/.git" ]] && repos+=("$(basename "$dir")")
done

if [[ ${#repos[@]} -eq 0 ]]; then
  echo "No git repos found in $DOMAIN_DIR"
  exit 0
fi

echo -e "${BOLD}Pulling ${#repos[@]} repos in parallel...${RESET}\n"

tmpdir=$(mktemp -d)
trap 'rm -rf "$tmpdir"' EXIT

pids=()

for name in "${repos[@]}"; do
  repo="$DOMAIN_DIR/$name"
  (
    { git -C "$repo" pull 2>&1; echo $? > "$tmpdir/$name.exit"; } \
      | tee "$tmpdir/$name.out" \
      | while IFS= read -r line; do
          printf "${C_NAME}[%-30s]${RESET} %s\n" "$name" "$line"
        done
  ) &
  pids+=($!)
done

for pid in "${pids[@]}"; do
  wait "$pid"
done

# Table helpers
C1=28; C2=8; C3=36

_top()  { printf '┌'; printf '─%.0s' $(seq 1 $((C1+2))); printf '┬'; printf '─%.0s' $(seq 1 $((C2+2))); printf '┬'; printf '─%.0s' $(seq 1 $((C3+2))); printf '┐\n'; }
_mid()  { printf '├'; printf '─%.0s' $(seq 1 $((C1+2))); printf '┼'; printf '─%.0s' $(seq 1 $((C2+2))); printf '┼'; printf '─%.0s' $(seq 1 $((C3+2))); printf '┤\n'; }
_bot()  { printf '└'; printf '─%.0s' $(seq 1 $((C1+2))); printf '┴'; printf '─%.0s' $(seq 1 $((C2+2))); printf '┴'; printf '─%.0s' $(seq 1 $((C3+2))); printf '┘\n'; }
_row()  { printf "│ %-${C1}s │ %-${C2}s │ %-${C3}s │\n" "$1" "$2" "$3"; }

echo ""
_top
_row "Repo" "Status" "Note"
_mid

ok=0; fail=0

for name in "${repos[@]}"; do
  code=$(cat "$tmpdir/$name.exit" 2>/dev/null || echo "?")
  out="$tmpdir/$name.out"

  if grep -q "Already up to date" "$out" 2>/dev/null; then
    note="Already up to date"
  elif [[ "$code" == "0" ]]; then
    note=$(grep -E "[0-9]+ file" "$out" 2>/dev/null | head -1 || echo "Updated")
    [[ -z "$note" ]] && note="Updated"
  else
    note=$(head -1 "$out" 2>/dev/null || echo "")
  fi

  # Truncate note to fit column
  note="${note:0:$C3}"

  if [[ "$code" == "0" ]]; then
    _row "$name" "✓  ok" "$note"
    ((ok++)) || true
  else
    _row "$name" "✗  fail" "$note"
    ((fail++)) || true
  fi
done

_bot
echo ""
echo -e "${BOLD}${ok} succeeded, ${fail} failed${RESET}"
[[ $fail -gt 0 ]] && exit 1 || exit 0
